<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dq.house.web.app.mapper.GraphInfoMapper">

    <select id="getListByRoomId" resultType="com.dq.house.web.app.vo.graph.GraphVo">
        select name, url
        from graph_info
        where item_id = #{id}
        and item_type = #{itemType}
        and is_deleted = 0
    </select>
</mapper>
