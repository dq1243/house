<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dq.house.web.app.mapper.RoomFacilityMapper">

    <!--    根据房间id获取设施列表-->
    <select id="getFacilityListByRoomId" resultType="com.dq.house.model.entity.FacilityInfo">
        select id, is_deleted, name, type, icon
        from facility_info
        where id in
              (select facility_id
               from room_facility
               where room_id = #{id}
                 and is_deleted = 0)
        and is_deleted = 0
    </select>
</mapper>
