<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dq.house.web.app.mapper.RoomPaymentTypeMapper">

    <select id="getListByRoomId" resultType="com.dq.house.model.entity.PaymentType">
        select id,
               name,
               pay_month_count,
               additional_info,
               is_deleted
        from payment_type
        where id in
              (select payment_type_id
               from room_payment_type
               where room_id = #{roomId})
    </select>
</mapper>
