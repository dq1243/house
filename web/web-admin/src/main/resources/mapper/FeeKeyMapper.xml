<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dq.house.web.admin.mapper.FeeKeyMapper">

    <resultMap id="FeeKeyVoMap" type="com.dq.house.web.admin.vo.fee.FeeKeyVo">
        <id column="fk.id" property="id"/>
        <result column="fk.name" property="name"/>
        <collection property="feeValueList" ofType="com.dq.house.model.entity.FeeValue">
            <id column="fv_id" property="id"/>
            <result column="fv_name" property="name"/>
            <result column="fv_key_id" property="feeKeyId"/>
            <result column="fv_unit" property="unit"/>
        </collection>
    </resultMap>

    <select id="feeInfoList" resultMap="FeeKeyVoMap">
        select fk.id, fk.name, fv.id as fv_id, fv.name as fv_name, fv.fee_key_id as fv_key_id, fv.unit as fv_unit
        from fee_key fk
                 left join fee_value fv on fk.id = fv.fee_key_id and fv.is_deleted = 0
        where fk.is_deleted = 0
    </select>
</mapper>
