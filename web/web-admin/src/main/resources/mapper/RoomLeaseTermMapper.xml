<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dq.house.web.admin.mapper.RoomLeaseTermMapper">
    <!--    根据房间Id获取租期列表-->
    <select id="getListByRoomId" resultType="com.dq.house.model.entity.LeaseTerm">
        select id, month_count, unit, is_deleted
        from lease_term
        where id in
              (select lease_term_id
               from room_lease_term rlt
               where rlt.room_id = #{id}
                 and is_deleted = 0)
    </select>
</mapper>
